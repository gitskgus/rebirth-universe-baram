<%- include('partials/header', { title: '안내' }) %>

<div class="container py-5">
  <div class="baram-page-header mb-5">
    <h3 class="mb-2">
      <i class="bi bi-compass me-2" style="color:var(--baram-jade)"></i>게임 안내
    </h3>
    <p style="color:var(--baram-text-sub)" class="mb-0">처음 오셨나요? 고려 대륙으로 떠나는 첫 걸음을 안내해 드립니다.</p>
  </div>

  <!-- 서버 소개 -->
  <div class="baram-card mb-5">
    <div class="baram-card-body p-4 p-md-5 text-center">
      <div style="font-size:2.4rem" class="mb-2">🌿</div>
      <h4 class="baram-section-title mb-3">놀자유니버스: 바람의나라에 오신 것을 환영합니다</h4>
      <p class="mb-0 mx-auto" style="color:var(--baram-text-sub); max-width:640px; line-height:1.8">
        고려의 신비로운 전설을 품은 대륙에서 전사 · 도적 · 주술사 · 도사가 되어
        몬스터를 사냥하고, 문파를 결성하며, 강호의 정점에 도전하세요.
        남녀노소 누구나 즐길 수 있는 정통 동양 판타지 MMORPG입니다.
      </p>
    </div>
  </div>

  <!-- 시작하기 -->
  <h4 class="baram-section-title mb-4"><i class="bi bi-play-circle-fill me-2" style="color:var(--baram-crimson)"></i>4단계로 시작하기</h4>
  <div class="row g-4 mb-5">
    <% steps.forEach(function(s) { %>
    <div class="col-md-6 col-lg-3">
      <div class="baram-step-card h-100">
        <div class="baram-step-no"><%= s.no %></div>
        <i class="bi <%= s.icon %> baram-step-icon"></i>
        <h6 class="baram-section-title mb-2"><%= s.title %></h6>
        <p class="mb-0" style="color:var(--baram-text-sub); font-size:0.85rem; line-height:1.6"><%= s.desc %></p>
      </div>
    </div>
    <% }); %>
  </div>

  <div class="text-center mb-5">
    <a href="/auth/register" class="btn baram-btn-primary me-2"><i class="bi bi-person-plus me-1"></i>회원가입하고 시작하기</a>
    <a href="/baram/info" class="btn baram-btn-outline"><i class="bi bi-journal-richtext me-1"></i>게임정보 보기</a>
  </div>

  <!-- 운영 정책 -->
  <h4 class="baram-section-title mb-3"><i class="bi bi-shield-shaded me-2" style="color:var(--baram-jade)"></i>운영 정책</h4>
  <div class="row g-3">
    <% policies.forEach(function(p) { %>
    <div class="col-md-4">
      <div class="baram-card h-100">
        <div class="baram-card-body">
          <i class="bi <%= p.icon %> fs-4 mb-2 d-block" style="color:var(--baram-jade)"></i>
          <h6 class="baram-section-title mb-2"><%= p.title %></h6>
          <p class="mb-0" style="color:var(--baram-text-sub); font-size:0.85rem; line-height:1.6"><%= p.desc %></p>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<%- include('partials/footer') %>
