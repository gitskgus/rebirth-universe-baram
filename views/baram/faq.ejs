<%- include('partials/header', { title: 'FAQ' }) %>

<div class="container py-5">
  <div class="baram-page-header mb-5 text-center">
    <h3 class="mb-2">
      <i class="bi bi-question-circle me-2" style="color:var(--baram-jade)"></i>자주 묻는 질문
    </h3>
    <p style="color:var(--baram-text-sub)">궁금한 점을 빠르게 확인하세요. 해결되지 않으면 <a href="/baram/help" class="baram-text-link">1:1 문의</a>를 이용해주세요.</p>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <% faqs.forEach(function(group) { %>
      <div class="mb-4">
        <h5 class="baram-faq-category mb-3">
          <span style="color:var(--baram-jade)" class="me-2">▸</span><%= group.category %>
        </h5>
        <div class="accordion baram-accordion" id="faq-<%= group.category %>">
          <% group.items.forEach(function(item, i) { %>
          <div class="accordion-item baram-accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button baram-accordion-btn collapsed" type="button"
                data-bs-toggle="collapse" data-bs-target="#faq-<%= group.category %>-<%= i %>">
                <span class="baram-faq-q me-2">Q.</span> <%= item.q %>
              </button>
            </h2>
            <div id="faq-<%= group.category %>-<%= i %>" class="accordion-collapse collapse">
              <div class="accordion-body baram-accordion-body">
                <span class="baram-faq-a me-2">A.</span> <%= item.a %>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% }); %>

      <div class="baram-card text-center p-4 mt-4">
        <i class="bi bi-headset fs-3 mb-2 d-block" style="color:var(--baram-jade)"></i>
        <p style="color:var(--baram-text-sub)" class="mb-3">원하는 답변을 찾지 못하셨나요?</p>
        <a href="/baram/help" class="btn baram-btn-primary">1:1 문의하기</a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
