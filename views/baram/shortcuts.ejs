<%- include('partials/header', { title: '단축키' }) %>

<div class="container py-5">
  <div class="baram-page-header mb-3">
    <h3 class="mb-0">
      <i class="bi bi-keyboard-fill me-2" style="color:var(--baram-crimson)"></i>단축키
    </h3>
  </div>

  <div class="baram-card mb-3">
    <div class="baram-card-body py-2">
      <h6 class="baram-section-title mb-2" style="font-size:0.86rem">⭐ 필수 단축키 — 처음 시작하신다면 먼저 외워두세요</h6>
      <div class="row g-1">
        <% essentialKeys.forEach(function(k) { %>
        <div class="col-sm-6 col-lg-4 d-flex align-items-center gap-2">
          <span class="baram-kbd"><%= k.keys %></span>
          <span style="color:var(--baram-text-sub); font-size:0.82rem"><%= k.desc %></span>
        </div>
        <% }); %>
      </div>
    </div>
  </div>

  <div class="row g-2">
    <% shortcutGroups.forEach(function(g) { %>
    <div class="<%= g.full ? 'col-12' : 'col-md-6 col-lg-4' %>">
      <div class="baram-card h-100 baram-shortcuts-card">
        <div class="baram-card-header"><i class="bi <%= g.icon %> me-2"></i><%= g.title %></div>
        <div class="table-responsive">
          <table class="table baram-table align-middle mb-0">
            <tbody>
              <% g.items.forEach(function(it) { %>
              <tr>
                <td style="width:<%= g.full ? '26%' : '42%' %>"><span class="baram-kbd"><%= it.keys %></span></td>
                <td style="color:var(--baram-text-sub); font-size:0.8rem"><%= it.desc %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<%- include('partials/footer') %>
