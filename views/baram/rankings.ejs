<%- include('partials/header', { title: '랭킹' }) %>

<div class="container py-5">
  <div class="baram-page-header mb-4">
    <h3 class="mb-2">
      <i class="bi bi-trophy-fill me-2" style="color:var(--baram-gold)"></i>강호 랭킹
    </h3>
    <p style="color:var(--baram-text-sub)" class="mb-0">고려 대륙을 호령하는 영웅과 문파를 만나보세요. <span style="color:var(--baram-muted)">매일 새벽 4시 갱신</span></p>
  </div>

  <!-- 탭 -->
  <div class="baram-rank-tabs mb-4">
    <a href="/baram/rankings?tab=all"  class="baram-rank-tab <%= tab === 'all' ? 'active' : '' %>">종합</a>
    <% jobTabs.forEach(function(j) { %>
      <a href="/baram/rankings?tab=<%= encodeURIComponent(j) %>" class="baram-rank-tab <%= tab === j ? 'active' : '' %>">
        <span class="me-1"><%= jobMeta[j].icon %></span><%= j %>
      </a>
    <% }); %>
    <a href="/baram/rankings?tab=guild" class="baram-rank-tab <%= tab === 'guild' ? 'active' : '' %>">
      <i class="bi bi-flag-fill me-1"></i>문파
    </a>
  </div>

  <!-- 포디움 (TOP 3) -->
  <% var top3 = rows.slice(0, 3); %>
  <% if (top3.length === 3) { %>
  <div class="row g-3 mb-4 justify-content-center baram-podium">
    <% [1, 0, 2].forEach(function(idx) { var r = top3[idx]; %>
    <div class="col-6 col-md-4">
      <div class="baram-podium-card baram-podium--<%= r.rank %>">
        <div class="baram-podium-medal">
          <%= r.rank === 1 ? '🥇' : r.rank === 2 ? '🥈' : '🥉' %>
        </div>
        <% if (isGuild) { %>
          <div class="baram-podium-name"><i class="bi bi-flag-fill me-1"></i><%= r.name %></div>
          <div class="baram-podium-sub">문주 <%= r.master %></div>
          <div class="baram-podium-score"><%= r.power.toLocaleString() %> <span>세력</span></div>
        <% } else { %>
          <div class="baram-podium-name">
            <span class="baram-job-dot" style="background:<%= jobMeta[r.job].color %>"></span><%= r.name %>
          </div>
          <div class="baram-podium-sub"><%= jobMeta[r.job].icon %> <%= r.job %> · Lv.<%= r.level %></div>
          <div class="baram-podium-score">환산 <%= r.hwansan %> <span>도</span></div>
        <% } %>
      </div>
    </div>
    <% }); %>
  </div>
  <% } %>

  <!-- 랭킹 표 -->
  <div class="baram-card">
    <div class="table-responsive">
      <table class="table baram-table align-middle mb-0">
        <thead>
          <% if (isGuild) { %>
          <tr>
            <th style="width:72px">순위</th>
            <th>문파</th>
            <th>문주</th>
            <th class="text-end">세력</th>
            <th class="text-center d-none d-md-table-cell">문파원</th>
            <th class="d-none d-md-table-cell">영지</th>
          </tr>
          <% } else { %>
          <tr>
            <th style="width:72px">순위</th>
            <th>캐릭터</th>
            <th>직업</th>
            <th class="text-center">레벨</th>
            <th class="text-end">환산</th>
            <th class="text-end d-none d-md-table-cell">명성</th>
            <th class="d-none d-md-table-cell">문파</th>
          </tr>
          <% } %>
        </thead>
        <tbody>
          <% rows.forEach(function(r) { %>
          <tr>
            <td>
              <span class="baram-rank-num <%= r.rank <= 3 ? 'baram-rank-num--top' : '' %>"><%= r.rank %></span>
            </td>
            <% if (isGuild) { %>
              <td><span class="fw-bold" style="color:var(--baram-jade-dark)"><i class="bi bi-flag-fill me-1" style="color:var(--baram-crimson)"></i><%= r.name %></span></td>
              <td style="color:var(--baram-text-sub)"><%= r.master %></td>
              <td class="text-end fw-bold" style="color:var(--baram-gold)"><%= r.power.toLocaleString() %></td>
              <td class="text-center d-none d-md-table-cell" style="color:var(--baram-text-sub)"><%= r.members %>명</td>
              <td class="d-none d-md-table-cell" style="color:var(--baram-muted)"><%= r.territory %></td>
            <% } else { %>
              <td class="fw-semibold" style="color:var(--baram-text)"><%= r.name %></td>
              <td>
                <span class="baram-job-badge" style="background:<%= jobMeta[r.job].color %>"><%= jobMeta[r.job].icon %> <%= r.job %></span>
              </td>
              <td class="text-center" style="color:var(--baram-text-sub)">Lv.<%= r.level %></td>
              <td class="text-end fw-bold" style="color:var(--baram-jade-dark)"><%= r.hwansan %></td>
              <td class="text-end d-none d-md-table-cell" style="color:var(--baram-gold)"><%= r.fame.toLocaleString() %></td>
              <td class="d-none d-md-table-cell" style="color:var(--baram-muted)"><%= r.guild %></td>
            <% } %>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <p class="text-center mt-3 mb-0" style="color:var(--baram-muted); font-size:0.8rem">
    ※ 본 랭킹은 시연용 예시 데이터입니다.
  </p>
</div>

<%- include('partials/footer') %>
