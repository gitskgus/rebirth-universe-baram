<%- include('partials/header', { title: '랭킹' }) %>

<div class="container py-5">
  <div class="baram-page-header mb-4">
    <h3 class="mb-2">
      <i class="bi bi-trophy-fill me-2" style="color:var(--baram-gold)"></i>강호 랭킹
    </h3>
    <p style="color:var(--baram-text-sub)" class="mb-0">직업별 TOP 100 랭킹입니다.</p>
  </div>

  <% if (error) { %>
    <p class="text-center py-5" style="color:var(--baram-muted)"><%= error %></p>
  <% } else { %>
  <div class="row g-3">
    <% jobCodes.forEach(function(code) { var jm = jobMeta[jobNames[code]] || {}; var list = byJob[code] || []; %>
    <div class="col-12 col-md-6 col-lg">
      <div class="baram-card h-100" style="--job-color:<%= jm.color || 'var(--baram-jade)' %>">
        <div class="baram-rank-col-head" style="background:<%= jm.color || 'var(--baram-jade)' %>">
          <span class="me-1"><%= jm.icon || '' %></span><%= jobNames[code] %>
        </div>
        <% if (list.length === 0) { %>
          <p class="text-center py-4 mb-0" style="color:var(--baram-muted); font-size:0.8rem">데이터 없음</p>
        <% } else { %>
        <div class="baram-rank-col-list">
          <% list.forEach(function(r) { %>
          <div class="baram-rank-col-row">
            <span class="baram-rank-col-num"><%= r.rank %></span>
            <span class="baram-rank-col-name"><%= r.name %></span>
          </div>
          <% }); %>
        </div>
        <% } %>
        <div class="baram-rank-col-foot">등록 <%= list.length %>명</div>
      </div>
    </div>
    <% }); %>
  </div>
  <% } %>

  <p class="text-center mt-3 mb-0" style="color:var(--baram-muted); font-size:0.8rem">
    ※ 직업별 상위 100명까지 표시됩니다.
  </p>
</div>

<%- include('partials/footer') %>
