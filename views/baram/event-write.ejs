<%- include('partials/header', { title: '이벤트 등록' }) %>
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<style>
  .ql-toolbar.ql-snow { background: var(--baram-surface2); border: 1.5px solid var(--baram-border); border-bottom: none; border-radius: 8px 8px 0 0; }
  .ql-container.ql-snow { background: var(--baram-surface); border: 1.5px solid var(--baram-border); border-radius: 0 0 8px 8px; font-size: 0.95rem; }
  .ql-editor { min-height: 220px; color: var(--baram-text); }
  .ql-editor.ql-blank::before { color: var(--baram-muted); font-style: normal; }
  .ql-toolbar .ql-stroke { stroke: var(--baram-text-sub); }
  .ql-toolbar .ql-fill { fill: var(--baram-text-sub); }
  .ql-toolbar button:hover .ql-stroke, .ql-toolbar button.ql-active .ql-stroke { stroke: var(--baram-jade); }
  .ql-toolbar button:hover .ql-fill, .ql-toolbar button.ql-active .ql-fill { fill: var(--baram-jade); }
  .ql-toolbar .ql-picker-label { color: var(--baram-text-sub); }
  .ql-toolbar .ql-picker-options { background: var(--baram-surface); border-color: var(--baram-border); }
</style>

<div class="container py-5">
  <div class="baram-page-header mb-4">
    <h3><i class="bi bi-calendar-plus me-2" style="color:var(--baram-jade)"></i>이벤트 등록</h3>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/baram" class="baram-link">홈</a></li>
        <li class="breadcrumb-item"><a href="/baram/event" class="baram-link">이벤트</a></li>
        <li class="breadcrumb-item active baram-active">등록</li>
      </ol>
    </nav>
  </div>

  <div class="baram-card">
    <div class="baram-card-body p-4">
      <% if (error) { %>
      <div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= error %></div>
      <% } %>
      <form action="/baram/event/write" method="POST" id="eventForm">
        <div class="mb-3">
          <label class="form-label small" style="color:var(--baram-text-sub)">이벤트 제목</label>
          <input type="text" name="title" class="form-control baram-input" placeholder="이벤트 제목을 입력하세요" maxlength="100" required />
        </div>
        <div class="row g-3 mb-3">
          <div class="col-sm-6">
            <label class="form-label small" style="color:var(--baram-text-sub)">카테고리</label>
            <select name="category" class="form-select baram-input" required>
              <option value="시즌">시즌</option>
              <option value="신규">신규</option>
              <option value="길드">길드</option>
              <option value="출석">출석</option>
              <option value="경험치">경험치</option>
              <option value="기타">기타</option>
            </select>
          </div>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-sm-6">
            <label class="form-label small" style="color:var(--baram-text-sub)">시작일</label>
            <input type="date" name="startAt" class="form-control baram-input" required />
          </div>
          <div class="col-sm-6">
            <label class="form-label small" style="color:var(--baram-text-sub)">종료일</label>
            <input type="date" name="endAt" class="form-control baram-input" required />
          </div>
        </div>
        <div class="mb-4">
          <label class="form-label small" style="color:var(--baram-text-sub)">이벤트 설명</label>
          <div id="quill-editor"></div>
          <input type="hidden" name="description" id="description-input">
        </div>
        <div class="d-flex flex-column flex-sm-row gap-2 justify-content-sm-end">
          <a href="/baram/event" class="btn baram-btn-outline">취소</a>
          <button type="submit" class="btn baram-btn-primary"><i class="bi bi-check-lg me-1"></i>등록하기</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
  const quill = new Quill('#quill-editor', {
    theme: 'snow',
    placeholder: '이벤트 내용을 상세히 작성해주세요.',
    modules: { toolbar: [[{ header: [1,2,3,false] }],['bold','italic','underline','strike'],[{ color:[] },{ background:[] }],[{ list:'ordered' },{ list:'bullet' }],[{ align:[] }],['link','image'],['clean']] }
  });
  document.getElementById('eventForm').addEventListener('submit', function(e) {
    if (quill.getText().trim().length === 0) { e.preventDefault(); alert('이벤트 설명을 입력해주세요.'); return; }
    document.getElementById('description-input').value = quill.root.innerHTML;
  });
</script>

<%- include('partials/footer') %>
