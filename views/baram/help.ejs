<%- include('partials/header', { title: '고객센터' }) %>

<div class="container py-5">
  <div class="baram-page-header mb-5 text-center">
    <h3 class="mb-2"><i class="bi bi-headset me-2" style="color:var(--baram-jade)"></i>고객센터</h3>
    <p style="color:var(--baram-text-sub)">운영팀이 최대한 빠르게 답변드리겠습니다. (평일 10:00 ~ 18:00)</p>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-7">

      <% if (success) { %>
      <div class="baram-card text-center p-5 mb-4">
        <i class="bi bi-check-circle-fill fs-1 mb-3 d-block" style="color:var(--baram-jade)"></i>
        <h5 style="color:var(--baram-text)" class="mb-2">문의가 접수되었습니다!</h5>
        <p style="color:var(--baram-text-sub)" class="mb-4">확인 후 이메일로 답변드리겠습니다. (영업일 기준 1~3일 소요)</p>
        <a href="/baram" class="btn baram-btn-primary">홈으로 돌아가기</a>
      </div>
      <% } else { %>

      <div class="baram-card mb-4">
        <div class="baram-card-header">
          <h6 class="mb-0"><i class="bi bi-pencil-square me-2" style="color:var(--baram-jade)"></i>1:1 문의</h6>
        </div>
        <div class="baram-card-body p-4">
          <form action="/baram/help" method="POST">
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label small" style="color:var(--baram-text-sub)">이름 / 닉네임</label>
                <input type="text" name="name" class="form-control baram-input"
                  placeholder="닉네임 입력" value="<%= user ? user.username : '' %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label small" style="color:var(--baram-text-sub)">이메일</label>
                <input type="email" name="email" class="form-control baram-input"
                  placeholder="답변 받을 이메일" value="<%= user ? user.email : '' %>" required />
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label small" style="color:var(--baram-text-sub)">문의 유형</label>
              <select name="subject" class="form-select baram-input" required>
                <option value="">선택해주세요</option>
                <option value="계정 문의">계정 문의</option>
                <option value="게임 버그 신고">게임 버그 신고</option>
                <option value="결제/환불">결제 / 환불</option>
                <option value="아이템 분실">아이템 분실</option>
                <option value="길드 문의">길드 문의</option>
                <option value="기타">기타</option>
              </select>
            </div>
            <div class="mb-4">
              <label class="form-label small" style="color:var(--baram-text-sub)">문의 내용</label>
              <textarea name="message" class="form-control baram-input" rows="8"
                placeholder="문의 내용을 상세히 작성해주세요." required></textarea>
            </div>
            <button type="submit" class="btn baram-btn-primary w-100">
              <i class="bi bi-send me-1"></i>문의 접수
            </button>
          </form>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-6">
          <a href="/baram/faq" class="baram-card d-block p-3 text-decoration-none">
            <div class="d-flex align-items-center gap-3">
              <i class="bi bi-question-circle fs-4" style="color:var(--baram-jade)"></i>
              <div>
                <div class="fw-semibold small" style="color:var(--baram-text)">FAQ</div>
                <div class="small" style="color:var(--baram-muted)">자주 묻는 질문 확인</div>
              </div>
            </div>
          </a>
        </div>
        <div class="col-md-6">
          <a href="/baram/board/notice" class="baram-card d-block p-3 text-decoration-none">
            <div class="d-flex align-items-center gap-3">
              <i class="bi bi-megaphone fs-4" style="color:var(--baram-jade)"></i>
              <div>
                <div class="fw-semibold small" style="color:var(--baram-text)">공지사항</div>
                <div class="small" style="color:var(--baram-muted)">운영 공지 확인</div>
              </div>
            </div>
          </a>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
