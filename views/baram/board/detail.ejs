<%- include('../partials/header', { title: post.title }) %>

<div class="container py-5">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/baram" class="baram-link">홈</a></li>
      <li class="breadcrumb-item"><a href="<%= basePath %>/board/<%= boardType %>" class="baram-link"><%= boardName %></a></li>
      <li class="breadcrumb-item active baram-active text-truncate" style="max-width:200px"><%= post.title %></li>
    </ol>
  </nav>

  <div class="baram-card mb-4">
    <div class="baram-card-header">
      <% if (post.isPinned) { %><span class="baram-badge-pinned me-2">공지</span><% } %>
      <h4 class="mb-2" style="color:var(--baram-text); font-weight:800"><%= post.title %></h4>
      <div class="d-flex gap-3 small" style="color:var(--baram-muted)">
        <span><i class="bi bi-person me-1"></i><%= post.author %></span>
        <span><i class="bi bi-calendar me-1"></i><%= post.createdAt.toLocaleDateString('ko-KR') %></span>
        <span><i class="bi bi-eye me-1"></i><%= post.views || 0 %></span>
        <% if (post.likes) { %><span><i class="bi bi-heart me-1"></i><%= post.likes %></span><% } %>
      </div>
    </div>
    <div class="baram-card-body p-4">
      <div class="baram-post-content"><%- post.content %></div>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <a href="<%= basePath %>/board/<%= boardType %>" class="btn baram-btn-outline btn-sm">
      <i class="bi bi-list me-1"></i>목록으로
    </a>
    <% if (boardType === 'free' && user) { %>
    <a href="/baram/board/free/write" class="btn baram-btn-primary btn-sm">
      <i class="bi bi-pencil me-1"></i>글쓰기
    </a>
    <% } %>
  </div>

  <% if (boardType === 'free') { %>
  <div class="baram-card">
    <div class="baram-card-header">
      <h6 class="mb-0">
        <i class="bi bi-chat-dots me-2" style="color:var(--baram-jade)"></i>댓글
        <% if (post.comments && post.comments.length > 0) { %>
          <span class="baram-count-badge ms-1"><%= post.comments.length %></span>
        <% } %>
      </h6>
    </div>
    <div class="baram-card-body">
      <% if (post.comments && post.comments.length > 0) { %>
        <% post.comments.forEach(function(c) { %>
        <div class="baram-comment-item d-flex gap-3 py-3">
          <div class="baram-comment-avatar flex-shrink-0">
            <i class="bi bi-person-circle fs-4" style="color:var(--baram-jade)"></i>
          </div>
          <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2 mb-1">
              <span class="fw-semibold small" style="color:var(--baram-text)"><%= c.author %></span>
              <span style="font-size:0.75rem; color:var(--baram-muted)"><%= c.createdAt.toLocaleDateString('ko-KR') %></span>
            </div>
            <p class="mb-0 small" style="color:var(--baram-text-sub)"><%= c.content %></p>
          </div>
        </div>
        <% }); %>
      <% } else { %>
        <p class="text-center py-3 mb-0 small" style="color:var(--baram-muted)">첫 댓글을 남겨보세요!</p>
      <% } %>
      <div class="baram-comment-form mt-3 pt-3" style="border-top:1px solid var(--baram-border)">
        <% if (user) { %>
        <form action="/baram/board/free/<%= post.id %>/comment" method="POST">
          <div class="d-flex gap-2">
            <input type="text" name="content" class="form-control baram-input flex-grow-1" placeholder="댓글을 입력하세요..." required />
            <button type="submit" class="btn baram-btn-primary btn-sm px-3 flex-shrink-0">등록</button>
          </div>
        </form>
        <% } else { %>
        <div class="text-center py-2">
          <p class="small mb-2" style="color:var(--baram-muted)">댓글을 작성하려면 로그인이 필요합니다.</p>
          <a href="/auth/login" class="btn baram-btn-primary btn-sm">로그인하기</a>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
