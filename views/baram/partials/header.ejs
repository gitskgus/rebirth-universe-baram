<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>놀자유니버스: 바람의나라</title>
  <link rel="icon" type="png"  href="/../assets/img/logo.png" />

  <!-- 링크 공유 미리보기 (카카오톡 · 디스코드 · 페이스북 등) -->
  <% var ogTitle = (typeof title !== 'undefined' ? title + ' - ' : '') + '놀자유니버스: 바람의나라'; %>
  <% var ogDesc = typeof ogDescription !== 'undefined' ? ogDescription : '고려의 전설을 품은 대륙, 바람의나라의 모든 정보를 한곳에서.'; %>
  <% var ogImg = (typeof ogImage !== 'undefined' ? ogImage : siteUrl + '/assets/img/og-thumbnail.png'); %>
  <meta property="og:type" content="website" />
  <meta property="og:title" content="<%= ogTitle %>" />
  <meta property="og:description" content="<%= ogDesc %>" />
  <meta property="og:image" content="<%= ogImg %>" />
  <meta property="og:url" content="<%= siteUrl %><%= originalUrl %>" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= ogTitle %>" />
  <meta name="twitter:description" content="<%= ogDesc %>" />
  <meta name="twitter:image" content="<%= ogImg %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/baram.css" />
</head>
