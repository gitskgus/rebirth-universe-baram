<% if (totalPages > 1) {
  var qp = (typeof baseQuery !== 'undefined' && baseQuery) ? baseQuery : '';
  var WINDOW = 10;                                   // 한 번에 보여줄 페이지 번호 개수
  var blockStart = Math.floor((current - 1) / WINDOW) * WINDOW + 1;
  var blockEnd = Math.min(blockStart + WINDOW - 1, totalPages);
%>
<nav class="mt-4 d-flex justify-content-center">
  <ul class="pagination pagination-sm baram-pagination mb-0 flex-wrap">
    <% if (blockStart > 1) { %>
    <li class="page-item"><a class="page-link" href="?<%= qp %>page=<%= blockStart - 1 %>" aria-label="이전 <%= WINDOW %>개"><i class="bi bi-chevron-double-left"></i></a></li>
    <% } %>
    <% if (current > 1) { %>
    <li class="page-item"><a class="page-link" href="?<%= qp %>page=<%= current - 1 %>" aria-label="이전"><i class="bi bi-chevron-left"></i></a></li>
    <% } %>
    <% for (let p = blockStart; p <= blockEnd; p++) { %>
    <li class="page-item <%= p === current ? 'active' : '' %>"><a class="page-link" href="?<%= qp %>page=<%= p %>"><%= p %></a></li>
    <% } %>
    <% if (current < totalPages) { %>
    <li class="page-item"><a class="page-link" href="?<%= qp %>page=<%= current + 1 %>" aria-label="다음"><i class="bi bi-chevron-right"></i></a></li>
    <% } %>
    <% if (blockEnd < totalPages) { %>
    <li class="page-item"><a class="page-link" href="?<%= qp %>page=<%= blockEnd + 1 %>" aria-label="다음 <%= WINDOW %>개"><i class="bi bi-chevron-double-right"></i></a></li>
    <% } %>
  </ul>
</nav>
<% } %>
