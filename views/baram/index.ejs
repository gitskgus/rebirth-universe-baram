<%- include('partials/header', { title: '홈' }) %>

<!-- 바람의나라 히어로 배너 (이미지) -->
<section class="baram-hero" role="img" aria-label="바람의나라 메인 배너"></section>

<% if (false) { %>
<!-- 랭킹 하이라이트 (일단 비공개) -->
<section class="py-5" style="background:var(--baram-surface)">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="baram-section-title d-inline-block mb-0"><i class="bi bi-trophy-fill me-2" style="color:var(--baram-gold)"></i>랭킹</h2>
      </div>
      <a href="/baram/ranking" class="baram-text-link text-nowrap">전체보기 <i class="bi bi-chevron-right"></i></a>
    </div>

    <div class="row g-3">
      <div class="col-6 col-md-4 col-lg-2">
        <div class="baram-card h-100 text-center p-3">
          <div class="baram-rank-hl-icon" style="background:var(--baram-gold)"><i class="bi bi-trophy-fill"></i></div>
          <div class="baram-rank-hl-label">전체 1위</div>
          <div class="baram-rank-hl-name"><%= (rankingHighlights && rankingHighlights.overall) || '-' %></div>
        </div>
      </div>
      <% jobCodes.forEach(function(code) { var jm = jobMeta[jobNames[code]] || {}; %>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="baram-card h-100 text-center p-3">
          <div class="baram-rank-hl-icon" style="background:<%= jm.color || 'var(--baram-jade)' %>"><%= jm.icon || '' %></div>
          <div class="baram-rank-hl-label"><%= jobNames[code] %> 1위</div>
          <div class="baram-rank-hl-name"><%= (rankingHighlights && rankingHighlights.byJob[code]) || '-' %></div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- 게임정보 바로가기 -->
<section class="py-5">
  <div class="container">
    <div class="text-center mb-4">
      <h2 class="baram-section-title d-inline-block mb-0">게임정보</h2>
    </div>

    <div class="row g-4 justify-content-center">

      <!-- 직업 -->
      <div class="col-sm-6 col-lg-4">
        <a href="/baram/info" class="baram-card baram-feature-card h-100 text-decoration-none">
          <div class="baram-feature-head">
            <div class="baram-feature-icon"><i class="bi bi-people-fill"></i></div>
            <h5 class="baram-feature-title">직업</h5>
          </div>
          <p class="baram-feature-desc">전사·도적·도사·주술사·궁사 등 직업별 특성과 핵심 시스템을 한눈에 확인하세요.</p>
          <span class="baram-feature-link">자세히 보기 <i class="bi bi-chevron-right"></i></span>
        </a>
      </div>

      <!-- 몬스터 정보 -->
      <div class="col-sm-6 col-lg-4">
        <a href="/baram/monster-info" class="baram-card baram-feature-card h-100 text-decoration-none">
          <div class="baram-feature-head">
            <div class="baram-feature-icon"><i class="bi bi-bug-fill"></i></div>
            <h5 class="baram-feature-title">몬스터 정보</h5>
          </div>
          <p class="baram-feature-desc">사냥터별 몬스터의 능력치와 드롭 아이템을 미리 파악하세요.</p>
          <span class="baram-feature-link">자세히 보기 <i class="bi bi-chevron-right"></i></span>
        </a>
      </div>

      <!-- 아이템 정보 -->
      <div class="col-sm-6 col-lg-4">
        <a href="/baram/item-info" class="baram-card baram-feature-card h-100 text-decoration-none">
          <div class="baram-feature-head">
            <div class="baram-feature-icon"><i class="bi bi-box-seam-fill"></i></div>
            <h5 class="baram-feature-title">아이템 정보</h5>
          </div>
          <p class="baram-feature-desc">무기·방어구·소비 아이템의 능력치와 획득 정보를 살펴보세요.</p>
          <span class="baram-feature-link">자세히 보기 <i class="bi bi-chevron-right"></i></span>
        </a>
      </div>

      <!-- 아이템 조합 -->
      <div class="col-sm-6 col-lg-4">
        <a href="/baram/item-combination" class="baram-card baram-feature-card h-100 text-decoration-none">
          <div class="baram-feature-head">
            <div class="baram-feature-icon"><i class="bi bi-hammer"></i></div>
            <h5 class="baram-feature-title">아이템 조합</h5>
          </div>
          <p class="baram-feature-desc">재료와 조합법을 확인하고 원하는 아이템을 직접 만들어 보세요.</p>
          <span class="baram-feature-link">자세히 보기 <i class="bi bi-chevron-right"></i></span>
        </a>
      </div>

      <!-- 단축키 -->
      <div class="col-sm-6 col-lg-4">
        <a href="/baram/shortcuts" class="baram-card baram-feature-card h-100 text-decoration-none">
          <div class="baram-feature-head">
            <div class="baram-feature-icon"><i class="bi bi-keyboard-fill"></i></div>
            <h5 class="baram-feature-title">단축키</h5>
          </div>
          <p class="baram-feature-desc">필수 단축키부터 카테고리별 조작법까지 한눈에 확인하세요.</p>
          <span class="baram-feature-link">자세히 보기 <i class="bi bi-chevron-right"></i></span>
        </a>
      </div>

    </div>
  </div>
</section>

<%- include('partials/footer') %>
