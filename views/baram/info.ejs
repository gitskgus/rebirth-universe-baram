<%- include('partials/header', { title: '게임정보' }) %>

<div class="container py-5">
  <div class="baram-page-header mb-5">
    <h3 class="mb-2">
      <i class="bi bi-journal-richtext me-2" style="color:var(--baram-jade)"></i>게임정보
    </h3>
    <p style="color:var(--baram-text-sub)" class="mb-0">직업과 시스템, 모험의 무대가 될 고려 대륙을 소개합니다.</p>
  </div>

  <!-- 직업 -->
  <h4 class="baram-section-title mb-3"><i class="bi bi-people-fill me-2" style="color:var(--baram-crimson)"></i>직업</h4>
  <div class="row g-4 mb-5">
    <% jobs.forEach(function(job) { %>
    <div class="col-md-6 col-lg-4">
      <div class="baram-job-card h-100" style="--job-color:<%= job.color %>">
        <div class="baram-job-icon" style="background:<%= job.color %>"><%= job.icon %></div>
        <h5 class="baram-job-name"><%= job.name %></h5>
        <div class="baram-job-role"><%= job.role %></div>
        <p class="baram-job-tagline">“<%= job.tagline %>”</p>

        <!-- 전직 체계 -->
        <div class="baram-promo-chain mb-2">
          <% job.promotions.forEach(function(p, i) { %>
            <span class="baram-promo-step <%= i === 0 ? 'baram-promo-step--base' : '' %>"><%= p %></span>
            <% if (i < job.promotions.length - 1) { %><i class="bi bi-chevron-right baram-promo-arrow"></i><% } %>
          <% }); %>
        </div>

        <p class="baram-job-desc"><%= job.desc %></p>
        <div class="baram-job-stats">
          <% Object.keys(job.stats).forEach(function(k) { %>
          <div class="baram-stat-row">
            <span class="baram-stat-label"><%= k %></span>
            <span class="baram-stat-bar">
              <% for (var i = 1; i <= 5; i++) { %>
                <span class="baram-stat-pip <%= i <= job.stats[k] ? 'on' : '' %>"></span>
              <% } %>
            </span>
          </div>
          <% }); %>
        </div>
        <div class="baram-job-traits mb-3">
          <% job.traits.forEach(function(t) { %><span class="baram-job-trait"><%= t %></span><% }); %>
        </div>

        <button type="button" class="btn btn-sm baram-btn-outline baram-job-skill-btn w-100" data-bs-toggle="modal" data-bs-target="#skillModal-<%= job.key %>">
          <i class="bi bi-list-stars me-1"></i>전체 스킬 보기
        </button>
      </div>
    </div>
    <% }); %>

    <!-- 공용 스킬 (직업 카드 옆 빈 칸에 배치) -->
    <div class="col-md-6 col-lg-4">
      <div class="baram-job-card h-100" style="--job-color:#1F5C82">
        <div class="baram-job-icon" style="background:#1F5C82"><i class="bi bi-stars"></i></div>
        <h5 class="baram-job-name">공용 스킬</h5>
        <div class="baram-job-role">모든 직업 공통</div>
        <p class="baram-job-tagline">“누구나 익히는 고려 대륙의 기본 술법”</p>
        <p class="baram-job-desc">직업에 관계없이 모든 모험가가 배우는 이동 · 축복 · 기원 계열의 기본 술법입니다.</p>
        <ul class="baram-common-skill-list">
          <% commonSkills.forEach(function(s) { %>
          <li title="<%= s.desc %>"><%= s.name %></li>
          <% }); %>
        </ul>
      </div>
    </div>
  </div>

  <!-- 직업별 전체 스킬 모달 -->
  <% jobs.forEach(function(job) { %>
  <div class="modal fade baram-modal" id="skillModal-<%= job.key %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">
            <span class="me-2" style="font-size:1.2rem"><%= job.icon %></span><%= job.name %> 전체 스킬
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <ul class="baram-skill-list">
            <% job.skills.forEach(function(s) { %>
            <li class="baram-skill-item">
              <span class="baram-skill-lv">Lv.<%= s.lv %></span>
              <span class="baram-skill-name"><%= s.name %></span>
              <% if (s.note) { %><span class="baram-skill-note"><%= s.note %></span><% } %>
            </li>
            <% }); %>
          </ul>
          <p class="text-center mt-3 mb-0" style="color:var(--baram-muted); font-size:0.78rem">
            ※ 공용 스킬은 제외한 <%= job.name %> 고유 스킬 목록입니다. 공용 스킬은 위 ‘공용 스킬’ 섹션을 참고하세요.
          </p>
        </div>
      </div>
    </div>
  </div>
  <% }); %>

  <% if (false) { %>
  <!-- 핵심 시스템 -->
  <h4 class="baram-section-title mb-3"><i class="bi bi-gear-fill me-2" style="color:var(--baram-azure, #1F5C82)"></i>핵심 시스템</h4>
  <div class="row g-3 mb-5">
    <% systems.forEach(function(s) { %>
    <div class="col-md-6">
      <div class="baram-card h-100">
        <div class="baram-card-body d-flex gap-3">
          <div class="baram-system-icon"><%= s.icon %></div>
          <div>
            <h6 class="mb-1 baram-section-title"><%= s.name %></h6>
            <p class="mb-0" style="color:var(--baram-text-sub); font-size:0.86rem; line-height:1.6"><%= s.desc %></p>
          </div>
        </div>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- 주요 지역 -->
  <h4 class="baram-section-title mb-3"><i class="bi bi-geo-alt-fill me-2" style="color:var(--baram-gold)"></i>주요 지역</h4>
  <div class="baram-card">
    <div class="table-responsive">
      <table class="table baram-table align-middle mb-0">
        <thead>
          <tr>
            <th style="width:160px">지역</th>
            <th style="width:120px" class="text-center">권장 레벨</th>
            <th>설명</th>
          </tr>
        </thead>
        <tbody>
          <% regions.forEach(function(r) { %>
          <tr>
            <td class="fw-bold" style="color:var(--baram-jade-dark)"><i class="bi bi-pin-map-fill me-1" style="color:var(--baram-crimson)"></i><%= r.name %></td>
            <td class="text-center"><span class="baram-event-badge baram-event-upcoming"><%= r.level %></span></td>
            <td style="color:var(--baram-text-sub); font-size:0.88rem"><%= r.desc %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
