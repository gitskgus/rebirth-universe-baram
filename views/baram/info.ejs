<%- include('partials/header', { title: '게임정보' }) %>

<div class="container py-5">
  <div class="baram-page-header mb-5">
    <h3 class="mb-2">
      <i class="bi bi-journal-richtext me-2" style="color:var(--baram-jade)"></i>게임정보
    </h3>
    <p style="color:var(--baram-text-sub)" class="mb-0">직업과 시스템, 모험의 무대가 될 고려 대륙을 소개합니다.</p>
  </div>

  <!-- 직업 -->
  <h4 class="baram-section-title mb-3"><i class="bi bi-people-fill me-2" style="color:var(--baram-crimson)"></i>직업</h4>
  <div class="row g-4 mb-5">
    <% jobs.forEach(function(job) { %>
    <div class="col-md-6 col-lg-4">
      <div class="baram-job-card h-100" style="--job-color:<%= job.color %>">
        <div class="baram-job-icon" style="background:<%= job.color %>"><%= job.icon %></div>
        <h5 class="baram-job-name"><%= job.name %></h5>
        <div class="baram-job-role"><%= job.role %></div>
        <p class="baram-job-tagline">“<%= job.tagline %>”</p>

        <!-- 전직 체계 -->
        <div class="baram-promo-chain mb-2">
          <% job.promotions.forEach(function(p, i) { %>
            <span class="baram-promo-step <%= i === 0 ? 'baram-promo-step--base' : '' %>"><%= p.title %></span>
            <% if (i < job.promotions.length - 1) { %><i class="bi bi-chevron-right baram-promo-arrow"></i><% } %>
          <% }); %>
        </div>

        <p class="baram-job-desc"><%= job.desc %></p>
        <div class="baram-job-stats">
          <% Object.keys(job.stats).forEach(function(k) { %>
          <div class="baram-stat-row">
            <span class="baram-stat-label"><%= k %></span>
            <span class="baram-stat-bar">
              <% for (var i = 1; i <= 5; i++) { %>
                <span class="baram-stat-pip <%= i <= job.stats[k] ? 'on' : '' %>"></span>
              <% } %>
            </span>
          </div>
          <% }); %>
        </div>
        <div class="baram-job-traits mb-3">
          <% job.traits.forEach(function(t) { %><span class="baram-job-trait"><%= t %></span><% }); %>
        </div>

        <button type="button" class="btn btn-sm baram-btn-outline baram-job-skill-btn w-100" data-bs-toggle="modal" data-bs-target="#skillModal-<%= job.key %>">
          <i class="bi bi-list-stars me-1"></i>전체 스킬 보기
        </button>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- 공용 스킬 -->
  <h4 class="baram-section-title mb-2"><i class="bi bi-stars me-2" style="color:var(--baram-azure, #1F5C82)"></i>공용 스킬</h4>
  <p class="mb-3" style="color:var(--baram-text-sub); font-size:0.86rem">직업과 무관하게 모든 캐릭터가 배우는 스킬입니다. 직업별 소개에서는 반복하지 않습니다.</p>

  <h6 class="baram-section-title mb-2" style="font-size:0.9rem">전 직업 공통</h6>
  <div class="baram-card mb-4">
    <div class="table-responsive">
      <table class="table baram-table align-middle mb-0">
        <thead><tr><th style="width:140px">스킬</th><th style="min-width:160px">설명</th></tr></thead>
        <tbody>
          <% universalSkills.forEach(function(s) { %>
          <tr>
            <td class="fw-semibold" style="color:var(--baram-jade-dark)"><%= s.name %></td>
            <td style="color:var(--baram-text-sub); font-size:0.88rem"><%= s.desc %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <h6 class="baram-section-title mb-2" style="font-size:0.9rem">2개 이상 직업이 함께 배우는 스킬</h6>
  <p class="mb-2" style="color:var(--baram-muted); font-size:0.8rem">직업마다 배우는 레벨은 다르지만 효과는 동일합니다.</p>
  <div class="baram-card mb-5">
    <div class="table-responsive">
      <table class="table baram-table align-middle mb-0">
        <thead><tr><th style="min-width:80px">스킬</th><th style="min-width:140px">설명</th><th style="min-width:110px">배우는 직업</th></tr></thead>
        <tbody>
          <% sharedSkills.forEach(function(s) { %>
          <tr>
            <td class="fw-semibold" style="color:var(--baram-jade-dark)"><%= s.name %></td>
            <td style="color:var(--baram-text-sub); font-size:0.88rem"><%= s.desc %></td>
            <td>
              <% s.jobs.forEach(function(j) { var jm = jobMeta[j]; %>
              <span class="baram-job-badge me-1 mb-1 d-inline-block" style="background:<%= jm ? jm.color : 'var(--baram-muted)' %>"><%= jm ? jm.icon + ' ' : '' %><%= j %></span>
              <% }); %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- 직업별 상세 정보 모달 (승급 로드맵 · 고유 스킬 · 승급 스킬) -->
  <% jobs.forEach(function(job) { %>
  <div class="modal fade baram-modal" id="skillModal-<%= job.key %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">
            <span class="me-2" style="font-size:1.2rem"><%= job.icon %></span><%= job.name %> — <%= job.role %>
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">

          <h6 class="baram-section-title mb-2" style="font-size:0.9rem">승급 로드맵</h6>
          <div class="table-responsive mb-4">
            <table class="table table-sm baram-table align-middle mb-0">
              <thead><tr><th style="width:70px">단계</th><th style="width:90px">칭호</th><th style="min-width:140px">승급 조건</th></tr></thead>
              <tbody>
                <% job.promotions.forEach(function(p) { %>
                <tr>
                  <td class="fw-semibold"><%= p.tier %></td>
                  <td class="fw-semibold" style="color:var(--baram-jade-dark)"><%= p.title %></td>
                  <td style="color:var(--baram-text-sub); font-size:0.88rem"><%= p.req || '—' %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <h6 class="baram-section-title mb-2" style="font-size:0.9rem">고유 스킬 (레벨순)</h6>
          <div class="table-responsive mb-4">
            <table class="table table-sm baram-table align-middle mb-0">
              <thead><tr><th style="width:50px">Lv</th><th style="width:130px">스킬</th><th style="min-width:140px">설명</th></tr></thead>
              <tbody>
                <% job.skills.forEach(function(s) { %>
                <tr>
                  <td class="fw-semibold" style="color:var(--baram-gold)"><%= s.lv %></td>
                  <td class="fw-semibold"><%= s.name %></td>
                  <td style="color:var(--baram-text-sub); font-size:0.86rem"><%= s.desc %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <h6 class="baram-section-title mb-1" style="font-size:0.9rem">승급 스킬</h6>
          <p class="mb-2" style="color:var(--baram-muted); font-size:0.76rem">해당 승급을 완료하면 즉시 지급되며, 레벨업으로는 배울 수 없습니다.</p>
          <div class="table-responsive">
            <table class="table table-sm baram-table align-middle mb-0">
              <thead><tr><th style="width:90px">승급</th><th style="width:130px">스킬</th><th style="min-width:140px">설명</th></tr></thead>
              <tbody>
                <% job.promotionSkills.forEach(function(s) { %>
                <tr>
                  <td class="fw-semibold"><%= s.tier %></td>
                  <td class="fw-semibold"><%= s.name %></td>
                  <td style="color:var(--baram-text-sub); font-size:0.86rem"><%= s.desc %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <p class="text-center mt-3 mb-0" style="color:var(--baram-muted); font-size:0.78rem">
            ※ 공용 스킬은 제외한 <%= job.name %> 고유 스킬입니다. 공용 스킬은 위 ‘공용 스킬’ 섹션을 참고하세요.
          </p>
        </div>
      </div>
    </div>
  </div>
  <% }); %>

  <% if (false) { %>
  <!-- 핵심 시스템 -->
  <h4 class="baram-section-title mb-3"><i class="bi bi-gear-fill me-2" style="color:var(--baram-azure, #1F5C82)"></i>핵심 시스템</h4>
  <div class="row g-3 mb-5">
    <% systems.forEach(function(s) { %>
    <div class="col-md-6">
      <div class="baram-card h-100">
        <div class="baram-card-body d-flex gap-3">
          <div class="baram-system-icon"><%= s.icon %></div>
          <div>
            <h6 class="mb-1 baram-section-title"><%= s.name %></h6>
            <p class="mb-0" style="color:var(--baram-text-sub); font-size:0.86rem; line-height:1.6"><%= s.desc %></p>
          </div>
        </div>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- 주요 지역 -->
  <h4 class="baram-section-title mb-3"><i class="bi bi-geo-alt-fill me-2" style="color:var(--baram-gold)"></i>주요 지역</h4>
  <div class="baram-card">
    <div class="table-responsive">
      <table class="table baram-table align-middle mb-0">
        <thead>
          <tr>
            <th style="width:160px">지역</th>
            <th style="width:120px" class="text-center">권장 레벨</th>
            <th>설명</th>
          </tr>
        </thead>
        <tbody>
          <% regions.forEach(function(r) { %>
          <tr>
            <td class="fw-bold" style="color:var(--baram-jade-dark)"><i class="bi bi-pin-map-fill me-1" style="color:var(--baram-crimson)"></i><%= r.name %></td>
            <td class="text-center"><span class="baram-event-badge baram-event-upcoming"><%= r.level %></span></td>
            <td style="color:var(--baram-text-sub); font-size:0.88rem"><%= r.desc %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
