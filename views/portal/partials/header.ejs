<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>놀자유니버스</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/portal.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg portal-navbar sticky-top">
  <div class="container">
    <a class="navbar-brand portal-brand" href="/">
      <span class="portal-brand-icon">🎮</span>
      <span class="portal-brand-text">놀자유니버스</span>
    </a>
    <div class="d-flex align-items-center gap-2 ms-auto">
      <% if (user) { %>
        <span class="small fw-semibold" style="color:var(--portal-text-sub)">
          <i class="bi bi-person-fill me-1"></i><%= user.username %>
        </span>
        <form action="/auth/logout" method="POST" class="d-inline">
          <button type="submit" class="btn btn-sm btn-outline-light">로그아웃</button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="btn btn-sm btn-outline-light">로그인</a>
        <a href="/auth/register" class="btn btn-sm portal-btn-primary">회원가입</a>
      <% } %>
    </div>
  </div>
</nav>

<main>
